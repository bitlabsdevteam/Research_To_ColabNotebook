# Paper2Notebook — Docker Environment Variables
# These are the default values used by docker-compose.yml.
# Override by creating a .env file or passing env vars directly.

# Backend: Allowed CORS origin (the frontend URL as seen by the browser)
CORS_ORIGIN=http://localhost:3000

# Frontend: URL of the backend API (as seen by the browser, not the container name)
# For local Docker use, this is localhost since the browser connects directly.
NEXT_PUBLIC_API_URL=http://localhost:3001
